DB_USER=postgres
DB_PASS=change-me
DB_NAME=ttm_db

# JWT бекенда и ai-service (одно значение!)
SECRET_KEY=change-me-in-production-use-long-random-string

# Публичный URL сайта (SvelteKit ORIGIN и invite-ссылки бекенда)
PUBLIC_ORIGIN=https://velikoss.ru

# Обычно пусто: браузер ходит на тот же origin (/api/v1 через nginx)
# Оставьте пустым: браузер ходит на https://velikoss.ru/api/v1 через nginx.
# НЕ указывайте localhost или backend — иначе в проде не будет запросов к API.
# PUBLIC_API_URL=

# CORS бекенда (через запятую, если фронт на другом домене)
CORS_ORIGINS=https://velikoss.ru

# --- MinIO (S3-совместимое хранилище файлов) ---
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-minio-secret
S3_BUCKET=ttm-files
S3_REGION=us-east-1
S3_USE_SSL=false
# Внутри compose backend ходит на http://minio:9000 (задано в docker-compose.yaml)
# Публичные presigned-ссылки для браузера:
S3_PUBLIC_ENDPOINT=https://velikoss.ru/minio

# --- AI service (ghcr.io/ds-testkit/ai) ---
# openai | ollama (openai = любой OpenAI-compatible API)
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
# OpenAI: пусто. VseGPT: https://api.vsegpt.ru (→ …/v1/chat/completions)
# Ollama: http://ollama:11434
# AI_BASE_URL=https://api.vsegpt.ru
AI_BASE_URL=
AI_MAX_TASKS=80
AI_REQUEST_TIMEOUT_MS=120000

# Фронт: обычно пусто (same-origin /api/ai через nginx)
# PUBLIC_AI_SERVICE_URL=