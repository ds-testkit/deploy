DB_USER=postgres
DB_PASS=change-me
DB_NAME=ttm_db

# Публичный URL сайта (для SvelteKit ORIGIN)
PUBLIC_ORIGIN=https://velikoss.ru

# Обычно пусто: браузер ходит на тот же origin (/api/v1 через nginx)
# Оставьте пустым: браузер ходит на https://velikoss.ru/api/v1 через nginx.
# НЕ указывайте localhost или backend — иначе в проде не будет запросов к API.
# PUBLIC_API_URL=

# CORS бекенда (через запятую, если фронт на другом домене)
CORS_ORIGINS=https://velikoss.ru